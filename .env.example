# Environment for agentic-evalkit eval runs.
#
# agentic-evalkit never reads a .env file itself -- these are ordinary
# environment variables. Copy this file to .env (gitignored) and load it
# explicitly when invoking the CLI, e.g.:
#
#   uv run --env-file .env agentic-evalkit run eval.yaml --yes
#
# Everything here is optional: a public-dataset eval (the gsm8k preset with
# the packaged zero target) runs with no environment at all.


# --- Hugging Face datasets ---------------------------------------------------
# Token for private/gated datasets and higher Dataset Viewer rate limits.
# The curated public presets (openai/gsm8k, princeton-nlp/SWE-bench_Verified)
# need no token, and the standard credential store (`huggingface-cli login`)
# works as an alternative. Never logged and never written into manifests or
# reports (design §12; secret-safe error rendering in
# src/agentic_evalkit/errors.py).
HF_TOKEN=

# --- Dataset cache -----------------------------------------------------------
# Override the content-addressed dataset cache root (ADR-0004). Default: the
# platform user-cache directory (%LOCALAPPDATA% on Windows, $XDG_CACHE_HOME
# or ~/.cache elsewhere). Point at a per-run temp directory in CI to keep
# runs hermetic, or at a fast local disk for large datasets.
AGENTIC_EVALKIT_CACHE_DIR=

# --- HTTP execution targets --------------------------------------------------
# A manifest's `target.credential_hook` names an environment variable (any
# name you choose); the CLI reads it at run time and sends it as
# `Authorization: Bearer <value>`, so the credential never appears in the
# manifest file or the canonical run JSON (design §12). The name below
# matches examples/http_agent/eval.yaml -- rename it to whatever your own
# manifest declares.
HTTP_AGENT_EXAMPLE_TOKEN=
